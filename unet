)\n            fp_path    = os.path.join(fd, 'FirePred',    f'{date_str}_FirePred.tif')\n\n            # VIIRS_Day ch0-5\n            with rasterio.open(day_path) as src:\n                day_arr = src.read().astype(np.float32)\n            if day_arr.shape[0] < 7:\n                print(f'  SKIP {date_str}: VIIRS_Day only {day_arr.shape[0]} channels')\n                continue\n            for ch in range(6):\n                v = day_arr[ch].flatten()\n                v = v[~np.isnan(v)]\n                if len(v): accum[ch].append(v)\n\n            # VIIRS_Night ch0-1\n            if os.path.exists(night_path):\n                with rasterio.open(night_path) as src:\n                    night_arr = src.read().astype(np.float32)\n                for ch in range(min(2, night_arr.shape[0])):\n                    v = night_arr[ch].flatten()\n                    v = v[~np.isnan(v)]\n                    if len(v): accum[6 + ch].append(v)\n\n            # FirePred ch0-1 and ch3-18 (skip ch2 = label)\n            # Guard: only process if FirePred has exactly 19 channels\n            if os.path.exists(fp_path):\n                with rasterio.open(fp_path) as src:\n                    fp_arr = src.read().astype(np.float32)\n                if fp_arr.shape[0] != 19:\n                    print(f'  SKIP FirePred {date_str}: {fp_arr.shape[0]} channels '\n                          f'(expected 19) in {os.path.basename(fd)}')\n                    continue\n                fp_chans = list(range(2)) + list(range(3, 19))\n                for out_idx, fp_ch in enumerate(fp_chans):\n                    v = fp_arr[fp_ch].flatten()\n                    v = v[~np.isnan(v)]\n                    if len(v): accum[8 + out_idx].append(v)\n\n        print(f'  {fi+1:2d}/{len(sample)}  {os.path.basename(fd)}')\n\n    means = np.zeros(26, dtype=np.float32)\n    stds  = np.ones(26,  dtype=np.float32)\n    for ch in range(26):\n        if accum[ch]:\n            all_v     = np.concatenate(accum[ch])\n            means[ch] = all_v.mean()\n            stds[ch]  = all_v.std() + 1e-6\n    return means, stds\n\nprint('Computing normalisation statistics from 20 training fires...')\nCHAN_MEANS, CHAN_STDS = compute_norm_stats(train_fires)\n\nCHAN_NAMES = [\n    'I1','I2','I3','I4d','I5d','M11',\n    'I4n','I5n',\n    'FP0','FP1',\n    'FP3','FP4','FP5','FP6','FP7','FP8',\n    'FP9','FP10','FP11','FP12','FP13','FP14',\n    'FP15','FP16','FP17','FP18',\n]\n\nprint(f'\\n{\"Ch\":>3}  {\"Name\":>5}  {\"Mean\":>12}  {\"Std\":>12}')\nprint('-' * 40)\nfor ch in range(26):\n    print(f'{ch:3d}  {CHAN_NAMES[ch]:>5}  {CHAN_MEANS[ch]:12.4f}  {CHAN_STDS[ch]:12.4f}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:14:19.171073Z","iopub.execute_input":"2026-03-07T06:14:19.171627Z","iopub.status.idle":"2026-03-07T06:14:45.426658Z","shell.execute_reply.started":"2026-03-07T06:14:19.171597Z","shell.execute_reply":"2026-03-07T06:14:45.425984Z"}},"outputs":[{"name":"stdout","text":"Computing normalisation statistics from 20 training fires...\n   1/20  24332746\n   2/20  20700973\n   3/20  23159836\n   4/20  24462788\n  SKIP FirePred 2017-07-12: 12 channels (expected 19) in elephant_hill_fire\n  SKIP FirePred 2017-07-07: 12 channels (expected 19) in elephant_hill_fire\n  SKIP FirePred 2017-07-11: 12 channels (expected 19) in elephant_hill_fire\n   5/20  elephant_hill_fire\n   6/20  21889994\n   7/20  24191376\n  SKIP FirePred 2019-05-21: 12 channels (expected 19) in chuckegg_creek_fire\n  SKIP FirePred 2019-05-16: 12 channels (expected 19) in chuckegg_creek_fire\n  SKIP FirePred 2019-05-19: 12 channels (expected 19) in chuckegg_creek_fire\n   8/20  chuckegg_creek_fire\n   9/20  24332608\n  10/20  21890003\n  11/20  24461899\n  12/20  21997770\n  13/20  24332702\n  14/20  20901111\n  15/20  24332783\n  16/20  20702159\n  17/20  21804582\n  18/20  24103581\n  19/20  double_creek_fire\n  20/20  24332787\n\n Ch   Name          Mean           Std\n----------------------------------------\n  0     I1       19.5026       14.7449\n  1     I2       28.0019       13.9639\n  2     I3       23.3264       10.5338\n  3    I4d      312.0779       15.4361\n  4    I5d      300.0435       20.1276\n  5    M11       16.8632        9.3409\n  6    I4n      283.2437       11.4234\n  7    I5n      281.8994       12.9600\n  8    FP0     4003.6646     2177.7632\n  9    FP1     2143.6753     1132.4778\n 10    FP3        3.4820        1.3602\n 11    FP4      216.9669       74.3920\n 12    FP5      287.5723        6.5260\n 13    FP6      304.0526        6.9136\n 14    FP7       78.1580       20.1719\n 15    FP8        0.0061        0.0023\n 16    FP9        6.1999        6.9069\n 17   FP10      161.9065      108.7547\n 18   FP11     1067.5792      705.2908\n 19   FP12       -0.8412        1.9223\n 20   FP13        9.5971        3.8119\n 21   FP14        3.8379       13.3510\n 22   FP15        2.0042        1.6193\n 23   FP16        8.7922       46.0871\n 24   FP17       22.3612        5.7708\n 25   FP18        0.0058        0.0020\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Identify fires with non-standard FirePred channel count\n# and remove them from all splits\n# ---------------------------------------------------------------\ndef get_fp_channel_count(fire_dir):\n    fp_files = sorted(glob.glob(os.path.join(fire_dir, 'FirePred', '*.tif')))\n    if not fp_files:\n        return -1\n    with rasterio.open(fp_files[0]) as src:\n        return src.count\n\nprint('Checking FirePred channel counts across all fires...')\nbad_fires = []\nfor fd in fire_dirs:\n    n_ch = get_fp_channel_count(fd)\n    if n_ch != 19:\n        fid = os.path.basename(fd)\n        bad_fires.append(fd)\n        print(f'  NON-STANDARD: {fid}  FirePred channels={n_ch}')\n\nprint(f'\\nNon-standard fires found: {len(bad_fires)}')\n\n# Remove bad fires from all splits\nbad_set     = set(bad_fires)\ntrain_fires = [fd for fd in train_fires if fd not in bad_set]\nval_fires   = [fd for fd in val_fires   if fd not in bad_set]\ntest_fires  = [fd for fd in test_fires  if fd not in bad_set]\nfire_dirs   = [fd for fd in fire_dirs   if fd not in bad_set]\n\nprint(f'\\nFinal clean splits:')\nprint(f'  train : {len(train_fires)} fires')\nprint(f'  val   : {len(val_fires)} fires')\nprint(f'  test  : {len(test_fires)} fires')\nprint(f'  total : {len(fire_dirs)} fires')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:14:48.745479Z","iopub.execute_input":"2026-03-07T06:14:48.746213Z","iopub.status.idle":"2026-03-07T06:14:49.807978Z","shell.execute_reply.started":"2026-03-07T06:14:48.746180Z","shell.execute_reply":"2026-03-07T06:14:49.807381Z"}},"outputs":[{"name":"stdout","text":"Checking FirePred channel counts across all fires...\n  NON-STANDARD: chuckegg_creek_fire  FirePred channels=12\n  NON-STANDARD: elephant_hill_fire  FirePred channels=12\n  NON-STANDARD: sparks_lake_fire  FirePred channels=12\n  NON-STANDARD: swedish_fire  FirePred channels=12\n  NON-STANDARD: sydney_fire  FirePred channels=12\n\nNon-standard fires found: 5\n\nFinal clean splits:\n  train : 136 fires\n  val   : 13 fires\n  test  : 24 fires\n  total : 173 fires\n","output_type":"stream"}],"execution_count":7},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Dataset class\n#\n# One sample = a time window of T consecutive days from one fire.\n# Input  : (26, T, H, W) float32 -- normalised, NaN -> 0\n# Label  : (H, W) int64          -- binary burned area mask\n#\n# BA preprocessing (paper): I4/I5 day+night channels are replaced\n# by their cumulative pixel-wise maximum from fire day 0 to current\n# day, accumulating the thermal burn signature over time.\n#\n# Spatial handling:\n#   VIIRS shapes vary slightly across days (~595x595).\n#   All frames cropped to minimum H and W within the window.\n#   FirePred resized to match VIIRS shape (nearest neighbour).\n# ---------------------------------------------------------------\nclass TSSatFireDataset(Dataset):\n\n    def __init__(self, fire_dirs, task='ba', time_steps=4,\n                 interval=1, patch_size=64,\n                 chan_means=None, chan_stds=None, augment=False):\n        self.task        = task\n        self.time_steps  = time_steps\n        self.interval    = interval\n        self.patch_size  = patch_size\n        self.chan_means  = chan_means\n        self.chan_stds   = chan_stds\n        self.augment     = augment\n        self.samples     = []\n        self._build_index(fire_dirs)\n\n    # ----------------------------------------------------------\n    def _build_index(self, fire_dirs):\n        for fd in fire_dirs:\n            day_files = sorted(glob.glob(\n                os.path.join(fd, 'VIIRS_Day', '*.tif')))\n            if len(day_files) < self.time_steps:\n                continue\n            n = len(day_files)\n            start = 0\n            while start + self.time_steps <= n:\n                self.samples.append({\n                    'fire_dir'      : fd,\n                    'all_day_files' : day_files,\n                    'window_start'  : start,\n                    'window_end'    : start + self.time_steps - 1,\n                })\n                start += self.interval\n        print(f'Dataset: {len(self.samples)} samples  '\n              f'(task={self.task}, T={self.time_steps}, '\n              f'interval={self.interval})')\n\n    # ----------------------------------------------------------\n    def _date(self, day_path):\n        return os.path.basename(day_path).replace('_VIIRS_Day.tif', '')\n\n    # ----------------------------------------------------------\n    def _load_frame(self, fd, day_path, H, W):\n        \"\"\"Load one timestep and return (26, H, W) float32.\"\"\"\n        date_str   = self._date(day_path)\n        night_path = os.path.join(fd, 'VIIRS_Night',\n                                  f'{date_str}_VIIRS_Night.tif')\n        fp_path    = os.path.join(fd, 'FirePred',\n                                  f'{date_str}_FirePred.tif')\n\n        # VIIRS_Day: 6 spectral channels (ch0-5)\n        with rasterio.open(day_path) as src:\n            day_arr = src.read().astype(np.float32)   # (8, h, w)\n        spectral = day_arr[:6, :H, :W]               # (6, H, W)\n\n        # VIIRS_Night: 2 thermal channels\n        if os.path.exists(night_path):\n            with rasterio.open(night_path) as src:\n                night_arr = src.read().astype(np.float32)\n            night = night_arr[:2, :H, :W]\n        else:\n            night = np.full((2, H, W), np.nan, dtype=np.float32)\n\n        # FirePred: 19 channels, resize to (H, W), exclude ch2 (label)\n        if os.path.exists(fp_path):\n            with rasterio.open(fp_path) as src:\n                fp_arr = src.read().astype(np.float32)  # (19, fh, fw)\n            if fp_arr.shape[0] != 19:\n                fp_feat = np.zeros((18, H, W), dtype=np.float32)\n            else:\n                if fp_arr.shape[1] != H or fp_arr.shape[2] != W:\n                    t = torch.from_numpy(fp_arr).unsqueeze(0)\n                    t = F.interpolate(t, size=(H, W), mode='nearest')\n                    fp_arr = t.squeeze(0).numpy()\n                fp_feat = np.concatenate(\n                    [fp_arr[:2], fp_arr[3:]], axis=0)   # (18, H, W)\n        else:\n            fp_feat = np.zeros((18, H, W), dtype=np.float32)\n\n        return np.concatenate([spectral, night, fp_feat], axis=0)  # (26,H,W)\n\n    # ----------------------------------------------------------\n    def _load_label(self, fd, day_path, H, W):\n        date_str = self._date(day_path)\n        if self.task == 'af':\n            with rasterio.open(day_path) as src:\n                ch6 = src.read(7).astype(np.float32)  # band 7 = ch6\n            return (~np.isnan(ch6[:H, :W])).astype(np.float32)\n        else:\n            fp_path = os.path.join(fd, 'FirePred',\n                                   f'{date_str}_FirePred.tif')\n            if os.path.exists(fp_path):\n                with rasterio.open(fp_path) as src:\n                    ch2 = src.read(3).astype(np.float32)  # band 3 = ch2\n                if ch2.shape[0] != H or ch2.shape[1] != W:\n                    t = torch.from_numpy(ch2).unsqueeze(0).unsqueeze(0)\n                    t = F.interpolate(t, size=(H, W), mode='nearest')\n                    ch2 = t.squeeze().numpy()\n                return (ch2 > 0).astype(np.float32)\n            return np.zeros((H, W), dtype=np.float32)\n\n    # ----------------------------------------------------------\n    def _thermal_aggregation(self, stack, all_files, fd,\n                             window_start, window_end, H, W):\n        \"\"\"Replace I4/I5 channels with cumulative max from day 0.\"\"\"\n        history = []\n        for i in range(window_end + 1):\n            dp       = all_files[i]\n            date_str = self._date(dp)\n            np_path  = os.path.join(fd, 'VIIRS_Night',\n                                    f'{date_str}_VIIRS_Night.tif')\n            with rasterio.open(dp) as src:\n                i4d = src.read(4).astype(np.float32)[:H, :W]\n                i5d = src.read(5).astype(np.float32)[:H, :W]\n            if os.path.exists(np_path):\n                with rasterio.open(np_path) as src:\n                    i4n = src.read(1).astype(np.float32)[:H, :W]\n                    i5n = src.read(2).astype(np.float32)[:H, :W]\n            else:\n                i4n = np.full((H, W), np.nan, dtype=np.float32)\n                i5n = np.full((H, W), np.nan, dtype=np.float32)\n            history.append(np.stack([i4d, i5d, i4n, i5n]))  # (4,H,W)\n\n        for t in range(self.time_steps):\n            gd      = window_start + t\n            hist    = np.stack(history[:gd + 1])       # (D,4,H,W)\n            cummax  = np.nanmax(hist, axis=0)           # (4,H,W)\n            stack[t, 3] = cummax[0]  # I4 day\n            stack[t, 4] = cummax[1]  # I5 day\n            stack[t, 6] = cummax[2]  # I4 night\n            stack[t, 7] = cummax[3]  # I5 night\n        return stack\n\n    # ----------------------------------------------------------\n    def _normalise(self, stack):\n        if self.chan_means is None:\n            return stack\n        m = self.chan_means[np.newaxis, :, np.newaxis, np.newaxis]\n        s = self.chan_stds[ np.newaxis, :, np.newaxis, np.newaxis]\n        return (stack - m) / s\n\n    def _crop(self, stack, label):\n        if self.patch_size is None:\n            return stack, label\n        H, W = label.shape\n        if H <= self.patch_size and W <= self.patch_size:\n            return stack, label\n        r = random.randint(0, H - self.patch_size)\n        c = random.randint(0, W - self.patch_size)\n        p = self.patch_size\n        return stack[:, :, r:r+p, c:c+p], label[r:r+p, c:c+p]\n\n    def _augment(self, stack, label):\n        if random.random() > 0.5:\n            stack = stack[:, :, :, ::-1].copy()\n            label = label[:, ::-1].copy()\n        if random.random() > 0.5:\n            stack = stack[:, :, ::-1, :].copy()\n            label = label[::-1, :].copy()\n        return stack, label\n\n    # ----------------------------------------------------------\n    def __len__(self):\n        return len(self.samples)\n\n    def __getitem__(self, idx):\n        s            = self.samples[idx]\n        fd           = s['fire_dir']\n        all_files    = s['all_day_files']\n        window_start = s['window_start']\n        window_end   = s['window_end']\n        window_files = all_files[window_start:window_end + 1]\n\n        # Determine common spatial size for this window\n        shapes = []\n        for dp in window_files:\n            with rasterio.open(dp) as src:\n                shapes.append((src.height, src.width))\n        H = min(s[0] for s in shapes)\n        W = min(s[1] for s in shapes)\n\n        # Load all frames\n        frames = [self._load_frame(fd, dp, H, W)\n                  for dp in window_files]          # list of (26,H,W)\n        stack  = np.stack(frames, axis=0)          # (T,26,H,W)\n\n        # BA thermal aggregation\n        if self.task == 'ba':\n            stack = self._thermal_aggregation(\n                stack, all_files, fd, window_start, window_end, H, W)\n\n        # Label from last timestep\n        label = self._load_label(fd, window_files[-1], H, W)  # (H,W)\n\n        # Normalise then replace NaN/inf with 0\n        stack = self._normalise(stack)\n        stack = np.nan_to_num(stack, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # Crop and augment\n        stack, label = self._crop(stack, label)\n        if self.augment:\n            stack, label = self._augment(stack, label)\n\n        # (T,26,H,W) -> (26,T,H,W) then to tensor\n        x = torch.from_numpy(stack).permute(1, 0, 2, 3).float()\n        y = torch.from_numpy(label).long()\n        return x, y\n\n\nprint('TSSatFireDataset defined.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:14:58.720908Z","iopub.execute_input":"2026-03-07T06:14:58.721573Z","iopub.status.idle":"2026-03-07T06:14:58.747623Z","shell.execute_reply.started":"2026-03-07T06:14:58.721544Z","shell.execute_reply":"2026-03-07T06:14:58.747082Z"}},"outputs":[{"name":"stdout","text":"TSSatFireDataset defined.\n","output_type":"stream"}],"execution_count":8},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Identify fires with non-standard FirePred channel count\n# and remove them from all splits\n# ---------------------------------------------------------------\ndef get_fp_channel_count(fire_dir):\n    fp_files = sorted(glob.glob(os.path.join(fire_dir, 'FirePred', '*.tif')))\n    if not fp_files:\n        return -1\n    with rasterio.open(fp_files[0]) as src:\n        return src.count\n\nprint('Checking FirePred channel counts across all fires...')\nbad_fires = []\nfor fd in fire_dirs:\n    n_ch = get_fp_channel_count(fd)\n    if n_ch != 19:\n        fid = os.path.basename(fd)\n        bad_fires.append(fd)\n        print(f'  NON-STANDARD: {fid}  FirePred channels={n_ch}')\n\nprint(f'\\nNon-standard fires found: {len(bad_fires)}')\n\n# Remove bad fires from all splits\nbad_set     = set(bad_fires)\ntrain_fires = [fd for fd in train_fires if fd not in bad_set]\nval_fires   = [fd for fd in val_fires   if fd not in bad_set]\ntest_fires  = [fd for fd in test_fires  if fd not in bad_set]\nfire_dirs   = [fd for fd in fire_dirs   if fd not in bad_set]\n\nprint(f'\\nFinal clean splits:')\nprint(f'  train : {len(train_fires)} fires')\nprint(f'  val   : {len(val_fires)} fires')\nprint(f'  test  : {len(test_fires)} fires')\nprint(f'  total : {len(fire_dirs)} fires')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:15:02.193858Z","iopub.execute_input":"2026-03-07T06:15:02.194496Z","iopub.status.idle":"2026-03-07T06:15:02.922854Z","shell.execute_reply.started":"2026-03-07T06:15:02.194467Z","shell.execute_reply":"2026-03-07T06:15:02.922147Z"}},"outputs":[{"name":"stdout","text":"Checking FirePred channel counts across all fires...\n\nNon-standard fires found: 0\n\nFinal clean splits:\n  train : 136 fires\n  val   : 13 fires\n  test  : 24 fires\n  total : 173 fires\n","output_type":"stream"}],"execution_count":9},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Dataset class\n#\n# Input tensor shape: (C*T, H, W) where C=26, T=4 => 104 channels\n# Label: (H, W) binary int64\n#\n# Per-timestep channel layout (26 channels):\n#   [0-5]  VIIRS_Day ch0-5   : spectral bands\n#   [6-7]  VIIRS_Night ch0-1 : thermal night\n#   [8-25] FirePred ch0-1, ch3-18 : auxiliary (ch2 excluded = label)\n#\n# BA preprocessing: I4/I5 day+night replaced by cumulative max\n# from fire start through current timestep (paper Section Methods)\n# ---------------------------------------------------------------\nTIME_STEPS  = 4\nPATCH_SIZE  = 64\nIN_CHANNELS = 26 * TIME_STEPS   # 104\n\nclass TSSatFireDataset(Dataset):\n\n    def __init__(self, fire_dirs, task='ba', time_steps=TIME_STEPS,\n                 interval=1, patch_size=PATCH_SIZE,\n                 means=None, stds=None, augment=False):\n        self.task        = task\n        self.T           = time_steps\n        self.interval    = interval\n        self.patch_size  = patch_size\n        self.means       = means\n        self.stds        = stds\n        self.augment     = augment\n        self.samples     = []\n        self._build_index(fire_dirs)\n\n    # ------------------------------------------------------------------\n    def _build_index(self, fire_dirs):\n        skipped = 0\n        for fd in fire_dirs:\n            fp_files = sorted(glob.glob(os.path.join(fd, 'FirePred', '*.tif')))\n            # Guard: only use fires with exactly 19-channel FirePred\n            if fp_files:\n                with rasterio.open(fp_files[0]) as src:\n                    if src.count != 19:\n                        skipped += 1\n                        continue\n            day_files = sorted(glob.glob(\n                os.path.join(fd, 'VIIRS_Day', '*.tif')))\n            if len(day_files) < self.T:\n                skipped += 1\n                continue\n            n = len(day_files)\n            start = 0\n            while start + self.T <= n:\n                self.samples.append({\n                    'fire_dir'  : fd,\n                    'day_files' : day_files,\n                    'start'     : start,\n                    'end'       : start + self.T - 1,\n                })\n                start += self.interval\n        print(f'Dataset built: {len(self.samples)} samples  '\n              f'(task={self.task}, T={self.T}, '\n              f'interval={self.interval}, skipped={skipped} fires)')\n\n    # ------------------------------------------------------------------\n    def _date(self, path):\n        return os.path.basename(path).replace('_VIIRS_Day.tif', '')\n\n    # ------------------------------------------------------------------\n    def _load_timestep(self, fd, day_path, H, W):\n        \"\"\"Load one timestep and return (26, H, W) float32 array.\"\"\"\n        date_str   = self._date(day_path)\n        night_path = os.path.join(fd, 'VIIRS_Night',\n                                  f'{date_str}_VIIRS_Night.tif')\n        fp_path    = os.path.join(fd, 'FirePred',\n                                  f'{date_str}_FirePred.tif')\n\n        # VIIRS_Day ch0-5\n        with rasterio.open(day_path) as src:\n            day_arr = src.read().astype(np.float32)   # (8, h, w)\n        spectral = day_arr[:6, :H, :W]                # (6, H, W)\n\n        # VIIRS_Night ch0-1\n        if os.path.exists(night_path):\n            with rasterio.open(night_path) as src:\n                night_arr = src.read().astype(np.float32)  # (2, h, w)\n            night = night_arr[:2, :H, :W]\n        else:\n            night = np.full((2, H, W), np.nan, dtype=np.float32)\n\n        # FirePred ch0-1 and ch3-18 (skip ch2 = BA label)\n        if os.path.exists(fp_path):\n            with rasterio.open(fp_path) as src:\n                fp_arr = src.read().astype(np.float32)  # (19, hf, wf)\n            # Resize to VIIRS resolution\n            fp_t = torch.from_numpy(fp_arr).unsqueeze(0)\n            fp_t = F.interpolate(fp_t, size=(H, W), mode='nearest')\n            fp_arr = fp_t.squeeze(0).numpy()            # (19, H, W)\n            aux = np.concatenate(\n                [fp_arr[:2], fp_arr[3:]], axis=0)       # (18, H, W)\n        else:\n            aux = np.zeros((18, H, W), dtype=np.float32)\n\n        return np.concatenate([spectral, night, aux], axis=0)  # (26, H, W)\n\n    # ------------------------------------------------------------------\n    def _load_label(self, fd, day_path, H, W):\n        date_str = self._date(day_path)\n        if self.task == 'af':\n            with rasterio.open(day_path) as src:\n                ch6 = src.read(7).astype(np.float32)   # band 7 = ch6\n            return (~np.isnan(ch6[:H, :W])).astype(np.float32)\n        else:  # ba\n            fp_path = os.path.join(fd, 'FirePred',\n                                   f'{date_str}_FirePred.tif')\n            if os.path.exists(fp_path):\n                with rasterio.open(fp_path) as src:\n                    ch2 = src.read(3).astype(np.float32)  # band 3 = ch2\n                ch2_t = torch.from_numpy(ch2).unsqueeze(0).unsqueeze(0)\n                ch2_t = F.interpolate(ch2_t, size=(H, W), mode='nearest')\n                ch2   = ch2_t.squeeze().numpy()\n                return (ch2 > 0).astype(np.float32)\n            return np.zeros((H, W), dtype=np.float32)\n\n    # ------------------------------------------------------------------\n    def _thermal_cummax(self, fd, all_day_files, window_end, H, W):\n        \"\"\"Cumulative max of I4/I5 day+night from fire start to window_end.\"\"\"\n        history = []\n        for i in range(window_end + 1):\n            dp       = all_day_files[i]\n            date_str = self._date(dp)\n            np_path  = os.path.join(fd, 'VIIRS_Night',\n                                    f'{date_str}_VIIRS_Night.tif')\n            with rasterio.open(dp) as src:\n                i4d = src.read(4).astype(np.float32)[:H, :W]\n                i5d = src.read(5).astype(np.float32)[:H, :W]\n            if os.path.exists(np_path):\n                with rasterio.open(np_path) as src:\n                    i4n = src.read(1).astype(np.float32)[:H, :W]\n                    i5n = src.read(2).astype(np.float32)[:H, :W]\n            else:\n                i4n = np.full((H, W), np.nan, dtype=np.float32)\n                i5n = np.full((H, W), np.nan, dtype=np.float32)\n            history.append(np.stack([i4d, i5d, i4n, i5n]))  # (4, H, W)\n        return history\n\n    # ------------------------------------------------------------------\n    def __len__(self):\n        return len(self.samples)\n\n    def __getitem__(self, idx):\n        s          = self.samples[idx]\n        fd         = s['fire_dir']\n        all_files  = s['day_files']\n        win_start  = s['start']\n        win_end    = s['end']\n        win_files  = all_files[win_start : win_end + 1]\n\n        # Common spatial size: min across all window frames\n        shapes = []\n        for dp in win_files:\n            with rasterio.open(dp) as src:\n                shapes.append((src.height, src.width))\n        H = min(s[0] for s in shapes)\n        W = min(s[1] for s in shapes)\n\n        # Load all timesteps\n        frames = [self._load_timestep(fd, dp, H, W) for dp in win_files]\n\n        # BA thermal aggregation\n        if self.task == 'ba':\n            history = self._thermal_cummax(fd, all_files, win_end, H, W)\n            for t in range(self.T):\n                gd      = win_start + t\n                hist_t  = np.stack(history[:gd + 1])        # (D, 4, H, W)\n                cummax  = np.nanmax(hist_t, axis=0)          # (4, H, W)\n                frames[t][3] = cummax[0]   # I4 day\n                frames[t][4] = cummax[1]   # I5 day\n                frames[t][6] = cummax[2]   # I4 night\n                frames[t][7] = cummax[3]   # I5 night\n\n        stack = np.stack(frames, axis=0)   # (T, 26, H, W)\n\n        # Normalise\n        if self.means is not None:\n            stack = (stack - self.means[None, :, None, None]) / \\\n                     self.stds[None,  :, None, None]\n\n        # Replace NaN with 0\n        stack = np.nan_to_num(stack, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # Label from last timestep\n        label = self._load_label(fd, win_files[-1], H, W)  # (H, W)\n\n        # Random crop\n        if self.patch_size and H > self.patch_size and W > self.patch_size:\n            r = random.randint(0, H - self.patch_size)\n            c = random.randint(0, W - self.patch_size)\n            stack = stack[:, :, r:r+self.patch_size, c:c+self.patch_size]\n            label = label[r:r+self.patch_size, c:c+self.patch_size]\n\n        # Augment: random horizontal and vertical flip\n        if self.augment:\n            if random.random() > 0.5:\n                stack = stack[:, :, :, ::-1].copy()\n                label = label[:, ::-1].copy()\n            if random.random() > 0.5:\n                stack = stack[:, :, ::-1, :].copy()\n                label = label[::-1, :].copy()\n\n        # (T, 26, H, W) -> (26*T, H, W)  flatten time into channels\n        x = torch.from_numpy(\n            stack.reshape(-1, stack.shape[2], stack.shape[3])).float()\n        y = torch.from_numpy(label).long()\n        return x, y\n\nprint('TSSatFireDataset defined.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:15:13.377215Z","iopub.execute_input":"2026-03-07T06:15:13.377510Z","iopub.status.idle":"2026-03-07T06:15:13.402623Z","shell.execute_reply.started":"2026-03-07T06:15:13.377486Z","shell.execute_reply":"2026-03-07T06:15:13.402011Z"}},"outputs":[{"name":"stdout","text":"TSSatFireDataset defined.\n","output_type":"stream"}],"execution_count":10},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Instantiate datasets and dataloaders\n# Verify one batch shape before building the model\n# ---------------------------------------------------------------\ntrain_ds = TSSatFireDataset(\n    fire_dirs  = train_fires,\n    task       = 'ba',\n    time_steps = TIME_STEPS,\n    interval   = 1,\n    patch_size = PATCH_SIZE,\n    means      = CHAN_MEANS,\n    stds       = CHAN_STDS,\n    augment    = True,\n)\nval_ds = TSSatFireDataset(\n    fire_dirs  = val_fires,\n    task       = 'ba',\n    time_steps = TIME_STEPS,\n    interval   = TIME_STEPS,\n    patch_size = None,\n    means      = CHAN_MEANS,\n    stds       = CHAN_STDS,\n    augment    = False,\n)\ntest_ds = TSSat