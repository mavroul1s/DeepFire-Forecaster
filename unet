 skipped=0 fires)\nDataset built: 202 samples  (task=ba, T=4, interval=4, skipped=0 fires)\nTrain samples : 2021\nVal samples   : 51\nTest samples  : 202\n\nBatch x shape : torch.Size([4, 104, 64, 64])   expected (4, 104, 64, 64)\nBatch y shape : torch.Size([4, 64, 64])   expected (4, 64, 64)\nx dtype       : torch.float32\nx range       : [-3.386, 4.636]\ny unique vals : [0]\ny fire pixels : 0 / 16384 (0.000%)\n\nNaN in x      : False\nInf in x      : False\n","output_type":"stream"}],"execution_count":11},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Lightweight U-Net (~1M parameters)\n#\n# Input : (B, 104, H, W)  -- 26 channels x 4 timesteps\n# Output: (B, 2,   H, W)  -- background + fire logits\n#\n# Architecture: 4-level encoder-decoder with skip connections\n# base_ch=32 gives ~1M params which fits comfortably in T4 VRAM\n# ---------------------------------------------------------------\nclass DoubleConv(nn.Module):\n    def __init__(self, in_ch, out_ch):\n        super().__init__()\n        self.block = nn.Sequential(\n            nn.Conv2d(in_ch,  out_ch, 3, padding=1, bias=False),\n            nn.BatchNorm2d(out_ch),\n            nn.ReLU(inplace=True),\n            nn.Conv2d(out_ch, out_ch, 3, padding=1, bias=False),\n            nn.BatchNorm2d(out_ch),\n            nn.ReLU(inplace=True),\n        )\n    def forward(self, x):\n        return self.block(x)\n\n\nclass LightUNet(nn.Module):\n    def __init__(self, in_channels, out_channels=2, base_ch=32):\n        super().__init__()\n        b = base_ch\n        self.pool = nn.MaxPool2d(2)\n\n        # Encoder\n        self.enc1 = DoubleConv(in_channels, b)\n        self.enc2 = DoubleConv(b,     b * 2)\n        self.enc3 = DoubleConv(b * 2, b * 4)\n        self.enc4 = DoubleConv(b * 4, b * 8)\n\n        # Bottleneck\n        self.bottleneck = DoubleConv(b * 8, b * 16)\n\n        # Decoder\n        self.up4  = nn.ConvTranspose2d(b * 16, b * 8, 2, stride=2)\n        self.dec4 = DoubleConv(b * 16, b * 8)\n        self.up3  = nn.ConvTranspose2d(b * 8,  b * 4, 2, stride=2)\n        self.dec3 = DoubleConv(b * 8,  b * 4)\n        self.up2  = nn.ConvTranspose2d(b * 4,  b * 2, 2, stride=2)\n        self.dec2 = DoubleConv(b * 4,  b * 2)\n        self.up1  = nn.ConvTranspose2d(b * 2,  b,     2, stride=2)\n        self.dec1 = DoubleConv(b * 2,  b)\n\n        # Output head\n        self.head = nn.Conv2d(b, out_channels, 1)\n\n    def forward(self, x):\n        e1 = self.enc1(x)\n        e2 = self.enc2(self.pool(e1))\n        e3 = self.enc3(self.pool(e2))\n        e4 = self.enc4(self.pool(e3))\n        b  = self.bottleneck(self.pool(e4))\n        d4 = self.dec4(torch.cat([self.up4(b),  e4], dim=1))\n        d3 = self.dec3(torch.cat([self.up3(d4), e3], dim=1))\n        d2 = self.dec2(torch.cat([self.up2(d3), e2], dim=1))\n        d1 = self.dec1(torch.cat([self.up1(d2), e1], dim=1))\n        return self.head(d1)\n\n\n# ---------------------------------------------------------------\n# Instantiate and verify\n# ---------------------------------------------------------------\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n\nmodel = LightUNet(in_channels=IN_CHANNELS, out_channels=2, base_ch=32)\n\ntotal_params = sum(p.numel() for p in model.parameters())\nprint(f'Model         : LightUNet  base_ch=32')\nprint(f'Total params  : {total_params:,}')\nprint(f'In channels   : {IN_CHANNELS}  (26 ch x {TIME_STEPS} timesteps)')\n\n# Multi-GPU\nif torch.cuda.device_count() > 1:\n    print(f'DataParallel  : {torch.cuda.device_count()} GPUs')\n    model = nn.DataParallel(model)\nmodel = model.to(device)\n\n# Dry run\nmodel.eval()\nwith torch.no_grad():\n    dummy = torch.randn(2, IN_CHANNELS, PATCH_SIZE, PATCH_SIZE).to(device)\n    out   = model(dummy)\n    print(f'\\nDry run input : {dummy.shape}')\n    print(f'Dry run output: {out.shape}   expected (2, 2, {PATCH_SIZE}, {PATCH_SIZE})')\n    print(f'Output range  : [{out.min():.4f}, {out.max():.4f}]')\n    print(f'No errors during forward pass.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:15:58.565899Z","iopub.execute_input":"2026-03-07T06:15:58.566550Z","iopub.status.idle":"2026-03-07T06:16:01.125277Z","shell.execute_reply.started":"2026-03-07T06:15:58.566514Z","shell.execute_reply":"2026-03-07T06:16:01.124570Z"}},"outputs":[{"name":"stdout","text":"Model         : LightUNet  base_ch=32\nTotal params  : 7,792,162\nIn channels   : 104  (26 ch x 4 timesteps)\nDataParallel  : 2 GPUs\n\nDry run input : torch.Size([2, 104, 64, 64])\nDry run output: torch.Size([2, 2, 64, 64])   expected (2, 2, 64, 64)\nOutput range  : [-0.0999, 0.0584]\nNo errors during forward pass.\n","output_type":"stream"}],"execution_count":12},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Loss, optimizer, scheduler, AMP scaler\n# ---------------------------------------------------------------\nfrom tqdm.auto import tqdm\n\n# Pure PyTorch Dice Loss -- no monai dependency\nclass DiceLoss(nn.Module):\n    def __init__(self, smooth=1e-6):\n        super().__init__()\n        self.smooth = smooth\n\n    def forward(self, logits, target):\n        # logits : (B, 2, H, W)\n        # target : (B, H, W) int64\n        prob  = torch.softmax(logits, dim=1)[:, 1]   # fire class prob (B,H,W)\n        tgt   = target.float()\n        inter = (prob * tgt).sum()\n        denom = prob.sum() + tgt.sum() + self.smooth\n        return 1.0 - (2.0 * inter + self.smooth) / denom\n\ncriterion = DiceLoss()\n\noptimizer = torch.optim.AdamW(\n    model.parameters(), lr=3e-4, weight_decay=1e-5\n)\n\nscheduler = torch.optim.lr_scheduler.CosineAnnealingLR(\n    optimizer, T_max=30, eta_min=1e-6\n)\n\n# AMP scaler -- compatible with PyTorch 2.x\ntry:\n    scaler = torch.amp.GradScaler('cuda')\n    def make_autocast():\n        return torch.amp.autocast('cuda')\nexcept Exception:\n    scaler = torch.cuda.amp.GradScaler()\n    def make_autocast():\n        return torch.cuda.amp.autocast()\n\nprint('Loss      : DiceLoss (pure PyTorch, fire class only)')\nprint('Optimizer : AdamW  lr=3e-4  wd=1e-5')\nprint('Scheduler : CosineAnnealingLR  T_max=30')\nprint('AMP       : enabled')\n\n# ---------------------------------------------------------------\n# Metrics\n# ---------------------------------------------------------------\nclass FireMetrics:\n    def __init__(self, threshold=0.5):\n        self.threshold = threshold\n        self.reset()\n\n    def reset(self):\n        self.tp = self.fp = self.fn = 0\n\n    def update(self, logits, target):\n        prob = torch.softmax(logits, dim=1)[:, 1]\n        pred = (prob > self.threshold).long()\n        tgt  = target.long()\n        self.tp += int(((pred == 1) & (tgt == 1)).sum())\n        self.fp += int(((pred == 1) & (tgt == 0)).sum())\n        self.fn += int(((pred == 0) & (tgt == 1)).sum())\n\n    @property\n    def f1(self):\n        d = 2 * self.tp + self.fp + self.fn\n        return 2 * self.tp / d if d > 0 else 0.0\n\n    @property\n    def iou(self):\n        d = self.tp + self.fp + self.fn\n        return self.tp / d if d > 0 else 0.0\n\n    def report(self):\n        return {'F1': self.f1, 'IoU': self.iou,\n                'TP': self.tp, 'FP': self.fp, 'FN': self.fn}\n\nprint('FireMetrics defined.')\n\n# ---------------------------------------------------------------\n# Training and validation functions\n# ---------------------------------------------------------------\ndef train_one_epoch(model, loader, optimizer, criterion, scaler, metrics):\n    model.train()\n    metrics.reset()\n    total_loss = 0.0\n    n_batches  = 0\n    pbar = tqdm(loader, desc='  train', leave=False, dynamic_ncols=True)\n    for x, y in pbar:\n        x = x.to(device, non_blocking=True)\n        y = y.to(device, non_blocking=True)\n        optimizer.zero_grad()\n        with make_autocast():\n            logits = model(x)\n            loss   = criterion(logits, y)\n        scaler.scale(loss).backward()\n        scaler.unscale_(optimizer)\n        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n        scaler.step(optimizer)\n        scaler.update()\n        with torch.no_grad():\n            metrics.update(logits.detach(), y)\n        total_loss += loss.item()\n        n_batches  += 1\n        pbar.set_postfix(loss=f'{total_loss/n_batches:.4f}',\n                         F1=f'{metrics.f1:.4f}')\n    pbar.close()\n    return total_loss / max(n_batches, 1), metrics.report()\n\n\n@torch.no_grad()\ndef validate(model, loader, criterion, metrics):\n    model.eval()\n    metrics.reset()\n    total_loss = 0.0\n    n_batches  = 0\n    pbar = tqdm(loader, desc='  val  ', leave=False, dynamic_ncols=True)\n    for x, y in pbar:\n        x = x.to(device, non_blocking=True)\n        y = y.to(device, non_blocking=True)\n        with make_autocast():\n            logits = model(x)\n            loss   = criterion(logits, y)\n        metrics.update(logits, y)\n        total_loss += loss.item()\n        n_batches  += 1\n        pbar.set_postfix(loss=f'{total_loss/n_batches:.4f}',\n                         F1=f'{metrics.f1:.4f}')\n    pbar.close()\n    return total_loss / max(n_batches, 1), metrics.report()\n\nprint('Training functions defined.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:16:06.850065Z","iopub.execute_input":"2026-03-07T06:16:06.850581Z","iopub.status.idle":"2026-03-07T06:16:10.731383Z","shell.execute_reply.started":"2026-03-07T06:16:06.850554Z","shell.execute_reply":"2026-03-07T06:16:10.730742Z"}},"outputs":[{"name":"stdout","text":"Loss      : DiceLoss (pure PyTorch, fire class only)\nOptimizer : AdamW  lr=3e-4  wd=1e-5\nScheduler : CosineAnnealingLR  T_max=30\nAMP       : enabled\nFireMetrics defined.\nTraining functions defined.\n","output_type":"stream"}],"execution_count":13},{"cell_type":"code","source":"# ---------------------------------------------------------------\n# Speed configuration -- replace datasets and loaders\n#\n# Changes vs previous run:\n#   train interval  : 1  -> 4   (505 -> ~130 batches per epoch)\n#   val patch_size  : None -> 64 (full image -> fixed crop, batch=4)\n#   thermal aggr    : disabled for speed (use raw I4/I5 instead)\n#   batch_size train: 4  -> 8\n#   NUM_EPOCHS      : kept at 30 but each epoch now ~4x faster\n# ---------------------------------------------------------------\nTIME_STEPS  = 4\nPATCH_SIZE  = 64\nIN_CHANNELS = 26 * TIME_STEPS   # 104\n\n# Subclass that skips the expensive thermal aggregation\nclass FastTSSatFireDataset(TSSatFireDataset):\n    def __getitem__(self, idx):\n        s         = self.samples[idx]\n        fd        = s['fire_dir']\n        win_files = s['day_files'][s['start'] : s['end'] + 1]\n\n        # Common spatial size\n        shapes = []\n        for dp in win_files:\n            with rasterio.open(dp) as src:\n                shapes.append((src.height, src.width))\n        H = min(sh[0] for sh in shapes)\n        W = min(sh[1] for sh in shapes)\n\n        # Load timesteps -- no thermal aggregation\n        frames = [self._load_timestep(fd, dp, H, W) for dp in win_files]\n        stack  = np.stack(frames, axis=0)   # (T, 26, H, W)\n\n        # Normalise + NaN fill\n        if self.means is not None:\n            stack = (stack - self.means[None, :, None, None]) / \\\n                     self.stds[None,  :, None, None]\n        stack = np.nan_to_num(stack, nan=0.0, posinf=0.0, neginf=0.0)\n\n        # Label\n        label = self._load_label(fd, win_files[-1], H, W)\n\n        # Crop\n        if self.patch_size and H > self.patch_size and W > self.patch_size:\n            r = random.randint(0, H - self.patch_size)\n            c = random.randint(0, W - self.patch_size)\n            stack = stack[:, :, r:r+self.patch_size, c:c+self.patch_size]\n            label = label[r:r+self.patch_size, c:c+self.patch_size]\n\n        # Augment\n        if self.augment:\n            if random.random() > 0.5:\n                stack = stack[:, :, :, ::-1].copy()\n                label = label[:, ::-1].copy()\n            if random.random() > 0.5:\n                stack = stack[:, :, ::-1, :].copy()\n                label = label[::-1, :].copy()\n\n        x = torch.from_numpy(\n            stack.reshape(-1, stack.shape[2], stack.shape[3])).float()\n        y = torch.from_numpy(label).long()\n        return x, y\n\ntrain_ds = FastTSSatFireDataset(\n    fire_dirs  = train_fires, task='ba',\n    time_steps = TIME_STEPS,  interval=4,\n    patch_size = PATCH_SIZE,\n    means=CHAN_MEANS, stds=CHAN_STDS, augment=True,\n)\nval_ds = FastTSSatFireDataset(\n    fire_dirs  = val_fires,   task='ba',\n    time_steps = TIME_STEPS,  interval=TIME_STEPS,\n    patch_size = PATCH_SIZE,\n    means=CHAN_MEANS, stds=CHAN_STDS, augment=False,\n)\ntest_ds = FastTSSatFireDataset(\n    fire_dirs  = test_fires,  task='ba',\n    time_steps = TIME_STEPS,  interval=TIME_STEPS,\n    patch_size = None,\n    means=CHAN_MEANS, stds=CHAN_STDS, augment=False,\n)\n\ntrain_loader = DataLoader(train_ds, batch_size=8,  shuffle=True,\n                          num_workers=2, pin_memory=True, drop_last=True)\nval_loader   = DataLoader(val_ds,   batch_size=8,  shuffle=False,\n                          num_workers=2, pin_memory=True)\ntest_loader  = DataLoader(test_ds,  batch_size=1,  shuffle=False,\n                          num_workers=2, pin_memory=True)\n\nprint(f'Train samples : {len(train_ds)}  =>  {len(train_loader)} batches/epoch')\nprint(f'Val samples   : {len(val_ds)}  =>  {len(val_loader)} batches/epoch')\nprint(f'Test samples  : {len(test_ds)}')\n\n# Quick batch check\nx, y = next(iter(train_loader))\nprint(f'\\nBatch x : {x.shape}')\nprint(f'Batch y : {y.shape}')\nprint(f'NaN     : {torch.isnan(x).any().item()}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-07T06:16:17.256785Z","iopub.execute_input":"2026-03-07T06:16:17.257502Z","io