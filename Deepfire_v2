\nimport torch.nn.functional as F\nimport torch.optim as optim\nimport rasterio\nimport matplotlib.pyplot as plt\nimport matplotlib.colors as mcolors\nfrom torch.utils.data import Dataset, DataLoader, random_split\nfrom tqdm.auto import tqdm\nfrom IPython.display import FileLink, display\n\n# ── Reproducibility ──────────────────────────────────────────────────────────\nSEED = 42\n\ndef set_seed(seed: int = SEED):\n    torch.manual_seed(seed)\n    torch.cuda.manual_seed_all(seed)\n    np.random.seed(seed)\n    torch.backends.cudnn.deterministic = True\n    torch.backends.cudnn.benchmark     = False\n\nset_seed()\n\nDEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(f\" Device: {DEVICE}\")\nprint(f\" PyTorch: {torch.__version__}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-02T16:17:18.751669Z","iopub.execute_input":"2026-03-02T16:17:18.752321Z","iopub.status.idle":"2026-03-02T16:17:22.963608Z","shell.execute_reply.started":"2026-03-02T16:17:18.752291Z","shell.execute_reply":"2026-03-02T16:17:22.962896Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 2. Global Configuration","metadata":{}},{"cell_type":"code","source":"# --- Paths -------------------------------------------------------------------\nDATA_ROOT  = \"/kaggle/input/ts-satfire/ts-satfire\"\nSAVE_DIR   = \"/kaggle/working\"\nMODEL_PATH = os.path.join(SAVE_DIR, \"deepfire_best.pt\")\n\n# --- Data --------------------------------------------------------------------\nSPATIAL_SIZE   = 128\nSEQ_LEN        = 3\nVIIRS_CHANNELS = 8           # bands per VIIRS_Day .tif\nNIGHT_CHANNELS = 2           # bands per VIIRS_Night .tif\nLULC_CLASSES   = 12\nLULC_EMBED_DIM = 8\nUSE_NIGHT      = True\n\n# --- Architecture ------------------------------------------------------------\nEMBED_DIM  = 192             # increased from 128 for more capacity\nNUM_HEADS  = 4\nNUM_LAYERS = 4               # increased from 3\nDROPOUT    = 0.1\n\n# --- 