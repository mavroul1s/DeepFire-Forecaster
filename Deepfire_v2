n, TN=tn)\n\n\n# --- Run inference -----------------------------------------------------------\nprint(f\"Running inference on {len(test_ds)} test samples ...\")\nresults = []\n\nwith torch.no_grad():\n    for idx in range(len(test_ds)):\n        viirs_b, lulc_b, tgt_b = test_ds[idx]\n        pred_t, _ = model(\n            viirs_b.unsqueeze(0).to(DEVICE),\n            lulc_b.unsqueeze(0).to(DEVICE),\n        )\n        pred_np  = pred_t.squeeze().cpu().numpy()\n        tgt_np   = tgt_b.squeeze().cpu().numpy()\n        viirs_np = viirs_b.numpy()   # [T, C, H, W]\n\n        results.append({\n            \"idx\":     idx,\n            \"metrics\": compute_metrics(pred_np, tgt_np),\n            \"pred\":    pred_np,\n            \"target\":  tgt_np,\n            \"viirs\":   viirs_np,\n        })\n\n# --- Aggregate stats ---------------------------------------------------------\nkeys = [\"IoU\", \"F1\", \"Recall\", \"Precision\", \"MAE\", \"RMSE\"]\nprint()\nprint(\"=\" * 62)\nprint(\"  Test Set Aggregate Metrics\")\nprint(\"=\" * 62)\nprint(f\"  Samples : {len(results)}\")\nfor k in keys:\n    vals = [r[\"metrics\"][k] for r in results]\n    print(f\"  {k:<12}: mean={np.mean(vals):.4f}  std={np.std(vals):.4f}\")\nprint(\"=\" * 62)\n\n# --- Select groups -----------------------------------------------------------\nranked   = sorted(results, key=lambda r: r[\"metrics\"][\"IoU\"])\nworst_3  = ranked[:3]\nbest_3   = ranked[-3:][::-1]\nrandom_3 = random.sample(results, 3)\n\n\ndef plot_group(sample_list, group_title):\n    \"\"\"\n    Plots N rows x 6 columns.\n    Columns: Day 1 | Day 2 | Day 3 | Ground Truth | Prediction | |Difference|\n    \"\"\"\n    n    = len(sample_list)\n    cols = [\"Input Day 1\", \"Input Day 2\", \"Input Day 3\",\n            \"Ground Truth\", \"Prediction\", \"Difference  |pred - truth|\"]\n    fig, axes = plt.subplots(n, 6, figsize=(22, 4.5 * n))\n    if n == 1:\n        axes = axes[np.newaxis, :]\n    fig.suptitle(group_title, fontsize=14, fontweight=\"bold\", y=1.01)\n\n    for row, r in enumerate(sample_list):\n        m    = r[\"metrics\"]\n        pred = r[\"pred\"]\n        tgt  = r[\"target\"]\n        diff = np.abs(pred - tgt)\n        vin  = r[\"viirs\"]   # [T, C, H, W]\n\n        row_label = (\n            f\"idx={r['idx']:04d}  IoU={m['IoU']:.3f}  \"\n            f\"F1={m['F1']:.3f}  Recall={m['Recall']:.3f}  \"\n            f\"Precision={m['Precision']:.3f}  \"\n            f\"MAE={m['MAE']:.4f}  RMSE={m['RMSE']:.4f}\"\n        )\n\n        for col in range(6):\n            ax = axes[row, col]\n            if col < 3:\n                im = ax.imshow(vin[col, 0], cmap=\"inferno\", vmin=0, vmax=1)\n            elif col == 3:\n                im = ax.imshow(tgt,  cmap=\"hot\",      vmin=0, vmax=1)\n            elif col == 4:\n                im = ax.imshow(pred, cmap=\"hot\",      vmin=0, vmax=1)\n            else:\n                im = ax.imshow(diff, cmap=\"RdYlGn_r\", vmin=0, vmax=1)\n\n            plt.colorbar(im, ax=ax, fraction=0.046, pad=0.04)\n            if row == 0:\n                ax.set_title(cols[col], fontsize=10, fontweight=\"bold\")\n            if col == 0:\n                ax.set_ylabel(row_label, fontsize=7.5, labelpad=4)\n            ax.set_xticks([])\n            ax.set_yticks([])\n\n    plt.tight_layout()\n    plt.show()\n    plt.close()\n\n\n# --- Learning curves ---------------------------------------------------------\nhistory  = checkpoint[\"history\"]\nepochs_x = list(range(1, len(history[\"train_loss\"]) + 1))\n\nfig, axes = plt.subplots(1, 3, figsize=(18, 4))\nfig.suptitle(\"Training History\", fontsize=13, fontweight=\"bold\")\naxes[0].plot(epochs_x, history[\"train_loss\"], label=\"Train\")\naxes[0].plot(epochs_x, history[\"val_loss\"],   label=\"Val\")\naxes[0].set_xlabel(\"Epoch\"); axes[0].set_ylabel(\"Loss\")\naxes[0].set_title(\"Loss\"); axes[0].legend(); axes[0].grid(alpha=0.3)\n\naxes[1].plot(epochs_x, history[\"val_iou\"], color=\"green\")\naxes[1].set_xlabel(\"Epoch\"); axes[1].set_ylabel(\"IoU\")\naxes[1].set_title(\"Validation IoU\"); axes[1].grid(alpha=0.3)\n\naxes[2].plot(epochs_x, history[\"lr\"], color=\"darkorange\")\naxes[2].set_xlabel(\"Step\"); axes[2].set_ylabel(\"LR\")\naxes[2].set_title(\"Learning Rate (OneCycleLR)\"); axes[2].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()\nplt.close()\n\n# --- Plot the three groups ---------------------------------------------------\nplot_group(best_3,   \"3 Best Predictions  (highest IoU)\")\nplot_group(worst_3,  \"3 Worst Predictions  (lowest IoU)\")\nplot_group(random_3, \"3 Random Predictions\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-02T18:09:57.526827Z","iopub.execute_input":"2026-03-02T18:09:57.527237Z","iopub.status.idle":"2026-03-02T18:10:12.096706Z","shell.execute_reply.started":"2026-03-02T18:09:57.527214Z","shell.execute_reply":"2026-03-02T18:10:12.095833Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}